# ── OpenRouter ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── Weaviate ─────────────────────────────────────────────────────────────────
WEAVIATE_URL=http://weaviate:8080

# ── TMDB (filmes, series, doramas) ───────────────────────────────────────────
# Chave gratuita em https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── Reddit (sem credenciais — usa URL publica .json) ─────────────────────────
# Nao precisa de credenciais

# ── AssemblyAI (transcricao de audio) ────────────────────────────────────────
ASSEMBLY_IA_KEY=your_assemblyai_api_key_here

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USER=open-anime
REDIS_PASSWORD=open-anime
REDIS_DB=0

# ── Modelos OpenRouter ───────────────────────────────────────────────────────
MODEL_ORCHESTRATOR=x-ai/grok-4.1-fast
MODEL_CHAT=x-ai/grok-4.1-fast
MODEL_SEARCH=x-ai/grok-4.1-fast

# ── Fase 2 — Documentos PDF ──────────────────────────────────────────────────
PDF_MAX_SIZE_MB=20
PDF_MAX_PAGES_FULL=30

# ── Fase 4 — Vagas (todas as fontes sao gratuitas, sem chave necessaria) ──────
JOBS_LIMITE_POR_FONTE=10
JOBS_LIMITE_TOTAL=30

# ── Fase 5 — Auto-candidatura ─────────────────────────────────────────────────
# Credenciais LinkedIn para Easy Apply (opcional)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
# Limite de candidaturas automaticas por dia
APPLY_DAILY_LIMIT=10
# Playwright headless (true em producao, false para debug local)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# ── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
