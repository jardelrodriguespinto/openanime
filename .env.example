# ── OpenRouter ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
COMPOSE_PROJECT_NAME=openanime

# ── Modelos OpenRouter (troque sem mexer no código) ──────────────────────────
MODEL_ORCHESTRATOR=meta-llama/llama-3-8b-instruct
MODEL_CHAT=anthropic/claude-sonnet-4-6
MODEL_SEARCH=meta-llama/llama-3-70b-instruct
MODEL_PROFILE=meta-llama/llama-3-8b-instruct

# ── OpenRouter Retry/Config ───────────────────────────────────────────────────
OPENROUTER_PER_MODEL_ATTEMPTS=2
OPENROUTER_RETRY_BASE_SECONDS=1.0
OPENROUTER_RETRY_MAX_SECONDS=4.0

# ── Telegram ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TMDB_API_KEY=your-tmdb-key

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_PORT_BROWZE=7474
NEO4J_PORT_BOLT=7687

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=open-anime
REDIS_PASSWORD=change-me
REDIS_DB=0

# ── PostgreSQL pgvector ───────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=anime
POSTGRES_USER=anime
POSTGRES_PASSWORD=change-me

# ── AssemblyAI ───────────────────────────────────────────────────────────────
ASSEMBLY_IA_KEY=your-assemblyai-key

# ── Dashboard Admin ───────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me
DASHBOARD_SECRET=change-me
DASHBOARD_PORT=8082
DASHBOARD_URL=http://localhost:8082
DASHBOARD_USER_ID=admin

# ── Ports ─────────────────────────────────────────────────────────────────────
BOT_WEBHOOK_PORT=8081

# ── Fase 2 — Documentos PDF ──────────────────────────────────────────────────
PDF_MAX_SIZE_MB=20
PDF_MAX_PAGES_FULL=30

# ── Fase 4 — Vagas ───────────────────────────────────────────────────────────
JOBS_LIMITE_POR_FONTE=10
JOBS_LIMITE_TOTAL=30

# ── Fase 5 — Auto-candidatura ───────────────────────────────────────────────────
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-linkedin-password
# Teto TOTAL de candidaturas aplicadas (conta no Redis, persiste entre runs).
# O bot pula vagas já aplicadas e segue aplicando até atingir este número de
# vagas APLICADAS (não percorridas). 0 = sem teto. Reset: apague a chave
# Redis 'linkedin:aplicacoes:admin' ou use contador_aplicacoes.reset_count().
LINKEDIN_TETO_APLICACOES=50

# ── Indeed ───────────────────────────────────────────────────────────────────
# Login é manual-first: o bot abre o Indeed e pausa para você concluir login/
# verificação (Cloudflare/Google/código por e-mail) no browser. O e-mail é só
# preenchido por conveniência quando o campo existe.
INDEED_EMAIL=you@example.com
INDEED_PASSWORD=your-indeed-password
# Palavra-chave de busca padrão (também customizável no dashboard, campo "Indeed").
INDEED_QUERY=desenvolvedor
# Localização opcional (parâmetro l= da busca). Vazio = Brasil todo.
INDEED_CIDADE=
# Nota mínima (0-100) de relevância vaga×currículo para aplicar. Fail-open:
# na dúvida, aplica. Só pula quem é claramente de outra área (0-39).
INDEED_LIMIAR_MATCH=40
# Teto TOTAL de candidaturas Indeed (conta no Redis, persiste entre runs).
# 0 = sem teto. Reset: apague a chave Redis 'indeed:aplicacoes:admin'.
INDEED_TETO_APLICACOES=50

# ── GeekHunter ───────────────────────────────────────────────────────────────
# Login por e-mail+senha (form). CAPTCHA/verificação cai em intervenção manual.
GEEK_HUNTER_EMAIL=you@example.com
GEEK_HUNTER_PASSWORD=your-geekhunter-password
# Palavra-chave de busca padrão (também customizável no dashboard, campo "GeekHunter").
GEEK_HUNTER_QUERY=desenvolvedor
# Nome completo e telefone do candidato — usados nos formulários (GeekHunter exige
# "Nome completo" e "Celular com DDD" obrigatórios). Fallback quando o perfil Neo4j
# não tem nome_real/telefone. LinkedIn URL vem do perfil (linkedin_url) ou LINKEDIN_URL.
CANDIDATO_NOME=Seu Nome Completo
CANDIDATO_TELEFONE=+55 11 99999-9999
LINKEDIN_URL=https://www.linkedin.com/in/seu-perfil
# Teto TOTAL de candidaturas GeekHunter (Redis, persiste). 0 = sem teto.
# Reset: apague a chave Redis 'geekhunter:aplicacoes:admin'.
GEEK_HUNTER_TETO_APLICACOES=50

GUPY_EMAIL=you@example.com
GUPY_PASSWORD=your-gupy-password
APPLY_DAILY_LIMIT=50
# Para Docker/local: true (headless, sem browser visivel)
# Para debug com browser visivel: false
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT_MS=45000
SESSIONS_DIR=/app/data/sessions
# Perfil Firefox persistente (cookies/sessão entre runs) — reduz CAPTCHA/verificação
# do Indeed: logue uma vez e a sessão fica salva. false = perfil zerado a cada run.
FIREFOX_PERSIST_PROFILE=true
FIREFOX_PROFILE_DIR=./data/firefox_profile
# Firefox "undetected": usa uma cópia do Firefox com o libxul patcheado para zerar
# navigator.webdriver — o sinal que o Cloudflare Turnstile usa pra travar o login do
# Indeed em loop. A cópia é preparada 1x (re-patcheia quando o Firefox atualiza) e
# compartilhada por LinkedIn/Indeed. false = usa o Firefox normal (login Indeed pode
# ficar preso no "Just a moment..." do Cloudflare).
FIREFOX_UNDETECTED=true
FIREFOX_UNDETECTED_DIR=./data/firefox_undetected

# ── Volumes (para deploy) ───────────────────────────────────────────────────────
HOST_DATA_DIR=./volumes/${COMPOSE_PROJECT_NAME}/neo4j/data
HOST_LOGS_DIR=./volumes/${COMPOSE_PROJECT_NAME}/neo4j/logs
HOST_REDIS_DIR=./volumes/${COMPOSE_PROJECT_NAME}/redis
HOST_PG_DATA_DIR=./volumes/${COMPOSE_PROJECT_NAME}/postgres
HOST_SESSIONS_DIR=./volumes/${COMPOSE_PROJECT_NAME}/sessions

# ── Logs ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=production
