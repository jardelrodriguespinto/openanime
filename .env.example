# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Weaviate
WEAVIATE_URL=http://weaviate:8080

# Reddit (sem API oficial - usa URL publica .json do Reddit)
# Nao precisa de credenciais

# Modelos OpenRouter
MODEL_ORCHESTRATOR=x-ai/grok-4.1-fast
MODEL_CHAT=x-ai/grok-4.1-fast
MODEL_SEARCH=x-ai/grok-4.1-fast

# AssemblyAI
ASSEMBLY_IA_KEY=your_assemblyai_api_key_here

# Logs
LOG_LEVEL=INFO
